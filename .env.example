# Receipt Roamer — Required Environment Variables
# Copy this to .env for local dev, or set in Railway's Variables tab for production.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found at: https://supabase.com/dashboard/project/<your-project>/settings/api
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=<anon-public-key>

# Exposed to the browser (Vite replaces import.meta.env.VITE_*)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<anon-public-key>

# ── Google Gemini AI ──────────────────────────────────────────────────────────
# Get a free API key at: https://aistudio.google.com/apikey
# Used server-side only (never exposed to the browser).
GEMINI_API_KEY=<your-gemini-api-key>

# ── Inbound email (Mailgun) ───────────────────────────────────────────────────
# Sign up at https://mailgun.com, enable Inbound Processing for your domain,
# and copy the Webhook Signing Key from Settings → Webhooks.
# Point your Mailgun route's webhook URL to: https://<your-app>/api/email-inbound
# Only emails from danzammit1@gmail.com will be processed.
MAILGUN_WEBHOOK_SIGNING_KEY=<key-from-mailgun-settings-webhooks>

# The inbound email address shown in the Upload page UI (VITE_ prefix = browser-visible).
# This is the address receipts are FORWARDED TO (e.g. receipts@mg.yourdomain.com).
# NOT the sender — the allowed sender (danzammit1@gmail.com) is hardcoded in the server.
VITE_INBOUND_EMAIL=receipts@mg.yourdomain.com

